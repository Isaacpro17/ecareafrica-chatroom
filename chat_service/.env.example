# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL (Chat Service dedicated DB) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=netrack_chat
DB_USER=chat_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must match the JWT signing secret used by the main Netrack auth system
JWT_SECRET=your_shared_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── Main Netrack System Bridge ────────────────────────────────────────────────
MAIN_API_BASE_URL=https://api.netrack.com
CHAT_SERVICE_KEY=your_shared_service_key_here

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# ── Redis (for caching and job queue) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── SMS Gateway ───────────────────────────────────────────────────────────────
SMS_GATEWAY_URL=https://sms.netrack.com/api/send
SMS_GATEWAY_API_KEY=your_sms_api_key_here

# ── Development flags ─────────────────────────────────────────────────────────
# Set to true to use mock user-context data instead of calling the real bridge
USE_MOCK_BRIDGE=true

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
